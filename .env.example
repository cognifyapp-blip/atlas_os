# ─── Database ───────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (used by Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── Clerk Auth ─────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Get this from Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET="whsec_..."

# ─── AI Providers ───────────────────────────────────────────────────────────
# OpenRouter (supports many free models including DeepSeek, etc.)
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# DeepSeek (if using directly)
DEEPSEEK_API_KEY="your_deepseek_api_key_here"

# Default AI Provider: openrouter | deepseek | openai
AI_PROVIDER="openrouter"

# Specific model to use with OpenRouter
OPENROUTER_MODEL="deepseek/deepseek-chat"

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000
APP_URL="http://localhost:3000"

# ─── Governance ──────────────────────────────────────────────────────────────
# supervised: all decisions require human CEO approval (default, safest)
# hybrid:     Atlas approves low/mid-risk, human reviews high-risk only
# autonomous: Atlas acts as CEO, approves within policy thresholds
GOVERNANCE_MODE="supervised"

# ─── Redis (Execution Engine) ────────────────────────────────────────────────
# Use a Redis URL (takes precedence) or individual settings
REDIS_URL="redis://localhost:6379"
# REDIS_HOST="127.0.0.1"
# REDIS_PORT="6379"
# REDIS_PASSWORD=""
# REDIS_TLS="false"
# REDIS_DB="0"
# REDIS_MAX_RETRY_ATTEMPTS="20"

# ─── Integrations — HubSpot ─────────────────────────────────────────────────
HUBSPOT_CLIENT_ID=""
HUBSPOT_CLIENT_SECRET=""

# ─── Integrations — QuickBooks ──────────────────────────────────────────────
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""

# ─── Integrations — Google ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Integrations — Slack ───────────────────────────────────────────────────
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
# Slack Incoming Webhook URL (alternative to Bot token — no OAuth required)
# Get from: https://api.slack.com/apps → your app → Incoming Webhooks
SLACK_WEBHOOK_URL=""

# ─── Integrations — Microsoft Teams / Azure ─────────────────────────────────
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""
AZURE_TENANT_ID=""
# Teams Incoming Webhook URL (alternative to Graph API — no OAuth required)
TEAMS_WEBHOOK_URL=""

# ─── Email Delivery ─────────────────────────────────────────────────────────
# Resend (primary — https://resend.com, free tier 100 emails/day)
RESEND_API_KEY=""
# SendGrid (fallback — https://sendgrid.com)
SENDGRID_API_KEY=""
# Sender address for outbound emails from Atlas OS
EMAIL_FROM="Atlas OS <noreply@yourdomain.com>"

# ─── Notifications ──────────────────────────────────────────────────────────
# Custom webhook URL for Atlas OS notifications (optional)
NOTIFICATION_WEBHOOK_URL=""
